// AlphA Holdings - Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── 통화 Enum ─────────────────────────────────────────────
enum Currency {
  USD
  KRW
  JPY
}

// ── 계좌 유형 Enum ────────────────────────────────────────
enum AccountType {
  US_DIRECT   // 미국 직투
  KR_DIRECT   // 한국 직투
  JP_DIRECT   // 일본 직투
  ISA         // 한국 ISA
  PENSION     // 연금저축펀드
  CASH        // 현금성 자산
}

// ── 리포트 유형 Enum ───────────────────────────────────────
enum ReportType {
  MONTHLY
  QUARTERLY
}

// ── 리포트 상태 Enum (임시저장 vs 작성 완료) ─────────────────
enum ReportStatus {
  DRAFT      // 임시저장: 수치 데이터만 입력, 텍스트 보완 예정
  PUBLISHED  // 작성 완료: 모든 필수 필드 검증 통과
}

// ── 자산 역할군 Enum (판단 보조 / Insight) ───────────────────
enum AssetRole {
  CORE       // 코어
  GROWTH     // 성장
  BOOSTER    // 부스터
  DEFENSIVE  // 방어
  INDEX      // 지수
  UNASSIGNED // 미지정 (리포트 종목용)
}

// ── 운용 프로필 (전략 관리용) ─────────────────────────────────
model Profile {
  id               String             @id @default(cuid())

  label            String             @unique  // "AlphA Holdings Portfolio", "MindongFolio" 등

  portfolioStrategies PortfolioStrategy[]
  accountInitialCapitals AccountInitialCapital[]

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

// ── 포트폴리오 전략 (프로필별 종목 목표 비중·역할) ─────────────
model PortfolioStrategy {
  id               String             @id @default(cuid())

  profileId        String
  profile          Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)

  ticker           String             // 종목 심볼
  displayName      String?            // 표시명 (검색·메타데이터 캐시, 예: ETF 한글명)
  role             AssetRole          @default(CORE)  // 역할군
  targetWeight     Float              // 목표 비중 (%)
  accountType      AccountType        @default(US_DIRECT)

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([profileId, ticker, accountType])
}

// ── 투자 리포트 (다중 통화 지원) ─────────────────────────
model Report {
  id              Int             @id @default(autoincrement())

  // 리포트 기본 정보
  type            ReportType                        // MONTHLY / QUARTERLY
  periodLabel     String                            // "2026-03", "2026-Q1" 등 표시용

  // 환율 스냅샷 (월별 리포트는 미사용 → null)
  usdRate         Float?                            // 리포트 기준 USD/KRW 환율
  jpyRate         Float?                            // 리포트 기준 JPY/KRW 환율 (100엔 기준)

  // 원화 환산 총액 (월별 리포트는 미사용 → null 보존)
  totalInvestedKrw  Float?                          // 총투자금 (원화 환산)
  totalCurrentKrw   Float?                          // 현재평가금 (원화 환산)

  // 운용 프로필
  profile         String          @default("AlphA Holdings Portfolio") // 운용 프로필 ("AlphA Holdings Portfolio" / "MindongFolio")

  // 리포트 상태 (임시저장 / 작성 완료)
  status          ReportStatus    @default(DRAFT)

  // 텍스트 기록
  summary         String?                           // 월/분기 증시 요약
  journal         String?                           // 투자 일지 / 느낀 점
  strategy        String?                           // 다음 전략
  earningsReview  String?                           // 분기별 어닝/실적 리뷰 (QUARTERLY 전용)

  // 관계
  portfolioItems   PortfolioItem[]
  newInvestments   NewInvestment[]
  reportAiComment ReportAiComment?
  initialCapitals AccountInitialCapital[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

// ── 계좌별 초기 원금 (프로필당 계좌 유형별 1건, 분기 리포트와 연동) ─────
model AccountInitialCapital {
  id          String      @id @default(cuid())

  profileId   String
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  accountType AccountType             // US_DIRECT / KR_DIRECT / JP_DIRECT / ISA / PENSION
  krwAmount   Float                   // 원화 환산 초기 원금

  reportId    Int                     // 입력한 첫 번째 분기 리포트 ID
  report      Report                  @relation(fields: [reportId], references: [id], onDelete: Restrict)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([profileId, accountType])
}

// ── 리포트 AI 분석 결과 캐시 (월별/분기별) ─────────────────────────────
model ReportAiComment {
  id              String   @id @default(uuid())

  reportId        Int      @unique
  report         Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  monthlySummary String   // 현재 상태 요약
  monthlyChange  String?  // 변화 설명
  nextAction     String   // 다음 액션 (규칙 기반)
  inputJson      Json     // AI 분석 입력 플래그 (규칙 엔진 결과)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ── 리포트 기준 포트폴리오 항목 (다중 통화) ───────────────
model PortfolioItem {
  id               Int          @id @default(autoincrement())

  reportId         Int
  report           Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  ticker           String                            // 종목 코드 (ex. AAPL, 삼성전자)
  displayName      String?                           // 표시명 (검색·메타 캐시)
  logoUrl          String?                           // 사용자 지정 종목 대표 이미지 URL (붙여넣기)
  sector           String?                           // 섹터 분류 (Technology, Financials, Consumer Discretionary 등)
  role             AssetRole   @default(CORE)         // 역할군 (CORE, GROWTH, BOOSTER, DEFENSIVE, INDEX, UNASSIGNED)
  accountType      AccountType                       // US_DIRECT / KR_DIRECT / ISA / JP_DIRECT / PENSION / CASH
  originalCurrency Currency                          // 원래 통화: USD / KRW / JPY
  originalAmount   Float                             // 원래 통화 기준 평가금액
  krwAmount        Float                             // 원화 환산 평가금액

  createdAt        DateTime     @default(now())
}

// ── 투자 분석 HTML (붙여넣기 등록 — 서버리스에서 public/ 쓰기 불가하므로 DB 저장) ──
model AnalysisReportUpload {
  id           String   @id @default(cuid())
  year         Int
  month        Int
  companyCode  String   @map("company_code")
  companyName  String   @map("company_name")
  title        String
  fileName     String   @map("file_name")
  verdict      String?
  html         String
  addedAt      DateTime @default(now()) @map("added_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([year, month, companyCode])
  @@map("analysis_report_upload")
}

// ── 신규 투자금 (리포트별, 계좌별) ───────────────────────────────
model NewInvestment {
  id               Int          @id @default(autoincrement())

  reportId         Int
  report           Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  accountType      AccountType                       // US_DIRECT / KR_DIRECT / ISA / JP_DIRECT / PENSION / CASH
  originalCurrency Currency                          // 원래 통화: USD / KRW / JPY
  originalAmount   Float                             // 원래 통화 기준 신규 투자금
  krwAmount        Float                             // 원화 환산 신규 투자금

  createdAt        DateTime     @default(now())
}

model AnalysisReport {
  id                String   @id @default(cuid())
  ticker            String
  companyName       String
  slug              String   @unique
  reportDate        DateTime @default(now())
  periodLabel       String
  reportData        Json
  rating            String
  totalScore        Float
  appliedModel      String
  /** 목록 카드용 커버 이미지 (data URL, 붙여넣기·파일 선택) */
  cardImageDataUrl  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}