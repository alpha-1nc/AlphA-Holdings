# Database
# SQLite database URL for Prisma
# 상대 경로는 프로젝트 루트 기준으로 절대 경로로 변환되어 열립니다 (prisma/dev.db 권장).
DATABASE_URL="file:./prisma/dev.db"

# Node Environment
# Options: development, production, test
NODE_ENV="development"

# Financial Modeling Prep (선택) — 분석 데이터 보완
# FMP_API_KEY=

# AI (Gemini) - 리포트 AI 분석용
# GitHub에는 올리지 말고, 홈서버에만 .env.production 으로 두세요.
GOOGLE_GENERATIVE_AI_API_KEY="your-api-key-here"

# 선택. 미설정 시 gemini-2.5-flash 사용.
# GEMINI_MODEL=gemini-2.5-flash

# 홈서버 + Cloudflare(또는 nginx 등) 뒤에서만 필요할 수 있음.
# 브라우저 주소창의 호스트만 적습니다 (https:// 제외, 포트는 보통 생략).
# 여러 개면 쉼표로 구분. 예: portfolio.example.com 또는 app.example.com,other.example.com
# 설정 후 반드시 서버에서 다시 빌드: npm run build && npm run start
SERVER_ACTION_ALLOWED_ORIGINS=
